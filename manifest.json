{
  "manifest_version": 3,
  "name": "reTenor",
  "version": "1.0",
  "description": "Replaces Twitter's GIF search with Tenor's",
  "permissions": [""],
  "host_permissions": [
    "https://api.tenor.com/*",
    "https://x.com/*",
    "https://twitter.com/*"
  ],
  "background": {
    "service_worker": "background.js",
	"scripts": ["background.js"]
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["inject.js"],
      "world": "MAIN"
    },
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"],
      "world": "ISOLATED"
    }
  ],
  "browser_specific_settings": {
  "gecko": {
    "id": "retenor@lunascape.gay",
    "data_collection_permissions": {
      "required": [
        "none"
      ]
    },
    "strict_min_version": "140.0"
  },
  "gecko_android":{
	"strict_min_version": "142.0"
  }
}
}
