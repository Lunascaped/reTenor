{
  "manifest_version": 3,
  "name": "reTenor",
  "version": "1.0",
  "description": "Replaces Twitter's GIF search with Tenor's",
  "permissions": ["webRequest"],
  "host_permissions": [
    "https://api.tenor.com/*",
    "https://x.com/*",
    "https://twitter.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["inject.js"],
      "world": "MAIN"
    },
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"],
      "world": "ISOLATED"
    }
  ]
}
